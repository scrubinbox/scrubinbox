{
  "name": "scrubinbox",
  "version": "0.1.0",
  "description": "Open-source Gmail inbox cleanup tool. Self-host for free, or use the hosted version at scrubinbox.com.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.15"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/scrubinbox/scrubinbox.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy -c wrangler.toml",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:worker": "tsc --noEmit -p worker/tsconfig.json"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "stripe": "^22.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.3.2",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.6",
    "svelte": "^5.43.5",
    "tailwindcss": "^4.1.17",
    "terser": "^5.49.0",
    "typescript": "^7.0.2",
    "vite": "^7.2.2",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
