{
  "name": "scrubinbox",
  "version": "0.1.0",
  "description": "Open-source Gmail inbox cleanup tool. Self-host for free, or use the hosted version at scrubinbox.com.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.15"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/scrubinbox/scrubinbox.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy -c wrangler.toml",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:worker": "tsc --noEmit -p worker/tsconfig.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/workers-types": "^4.20251101.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/postcss": "^4.1.17",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "svelte": "^5.43.5",
    "tailwindcss": "^4.1.17",
    "terser": "^5.46.1",
    "typescript": "^5.6.0",
    "vite": "^7.2.2",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
