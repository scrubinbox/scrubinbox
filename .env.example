# Local-dev secrets — copy to .env (gitignored) and fill in.
#
# One file for local development, per Cloudflare's guidance:
# "Choose to use either `.dev.vars` or `.env` but not both."
# https://developers.cloudflare.com/workers/configuration/environment-variables/#local-development-with-secrets
#
# Two audiences read this file:
#
# 1. Vite — for the SPA build. Inlines `import.meta.env.VITE_*` into the
#    JS bundle so src/lib/supabase/client.js can construct the client.
#    Only `VITE_*`-prefixed vars are exposed to the browser bundle.
#
# 2. The @cloudflare/vite-plugin embedded Worker — reads every var here
#    into the Worker's runtime env (c.env.SUPABASE_URL, c.env.STRIPE_*, ...).
#    Non-VITE_ vars are Worker-only.
#
# The overlap (SUPABASE_URL vs VITE_SUPABASE_URL, etc.) is unavoidable —
# Vite's `import.meta.env` only surfaces VITE_-prefixed names to the client,
# but the Worker uses the unprefixed names to match production wrangler
# secrets. Same value, two names.

# --- Client build (Vite) ---
# Staging values: Supabase dashboard for jjbychixggcefuxznprp → Project
# Settings → API. Use the `sb_publishable_...` key (Supabase's legacy `anon`
# JWT is being deprecated).
VITE_SUPABASE_URL=https://jjbychixggcefuxznprp.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Worker runtime (matches wrangler secrets set in staging/production) ---
SUPABASE_URL=https://jjbychixggcefuxznprp.supabase.co
SUPABASE_PUBLISHABLE_KEY=
# Bypasses RLS. Worker uses it only in the Stripe webhook handler.
SUPABASE_SECRET_KEY=

# Stripe test-mode values from https://dashboard.stripe.com/test/apikeys and
# https://dashboard.stripe.com/test/webhooks (register the local endpoint
# with `stripe listen --forward-to http://localhost:5173/api/webhooks/stripe`
# to capture a whsec_ for local dev).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
