# Local-dev secrets — copy to .env (gitignored) and fill in.
#
# Single .env file per Cloudflare's guidance:
# https://developers.cloudflare.com/workers/configuration/environment-variables/#local-development-with-secrets
#
# Read by two things:
# 1. Vite — inlines VITE_-prefixed vars into the client bundle (there are
#    currently none; auth flow lives entirely in the Worker).
# 2. The @cloudflare/vite-plugin embedded Worker — reads every var here into
#    the Worker's runtime env (`c.env.DATABASE_URL`, `c.env.STRIPE_*`, ...).
#    Matches the wrangler secret names set per-environment on the deployed
#    Workers via `wrangler secret put --env {staging,production} <NAME>`.
#
# For local dev, point DATABASE_URL at the Neon staging branch; use the
# staging Google OAuth client (with http://localhost:5173/api/auth/google/callback
# added as an Authorized redirect URI); Stripe stays in test mode.

# --- Database (Neon) ---
# Copy from Neon dashboard → project → Connection details → pooled connection
# string. Staging branch for local dev.
DATABASE_URL=

# --- Google OAuth (staging client) ---
# From Google Cloud Console → APIs & Services → Credentials. The staging
# OAuth client (1078917807011-vi5oval...). Add
# `http://localhost:5173/api/auth/google/callback` to its Authorized redirect
# URIs before running locally.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Session + refresh-token crypto ---
# Both are 32-byte random values, base64-encoded. Generate fresh ones for each
# machine — they are NOT shared with anything upstream. Losing them just
# invalidates all local sessions and forces a re-sign-in; refresh tokens are
# re-issued on next sign-in with prompt=consent.
#
#   openssl rand -base64 32
#
SESSION_SIGNING_SECRET=
REFRESH_TOKEN_ENCRYPTION_KEY=

# --- Stripe (test mode) ---
# From https://dashboard.stripe.com/test/apikeys and
# https://dashboard.stripe.com/test/webhooks. For local webhook testing run:
#   stripe listen --forward-to http://localhost:5173/api/webhooks/stripe
# and copy the `whsec_...` it prints.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
